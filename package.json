{
  "name": "dohc-viewer",
  "private": true,
  "version": "0.17.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "test:concurrency": "node --test scripts/operation-scope.test.mjs",
    "test:concurrency:browser": "node scripts/concurrency-state-smoke.mjs",
    "test:dialog-recovery": "node --test scripts/dialog-recovery.test.mjs",
    "check": "node scripts/release-check.mjs --quick",
    "check:exfat-macos": "node scripts/exfat-smoke-macos.mjs",
    "check:full": "node scripts/release-check.mjs --full",
    "check:bundle": "node scripts/release-check.mjs --full --bundle",
    "test:demo-flow": "node --test scripts/demo-flow.test.mjs",
    "check:linux": "node scripts/check-linux-package.mjs",
    "check:release-scripts": "node --test scripts/release-scripts.test.mjs",
    "test:session-activation": "node --test scripts/session-activation.test.mjs",
    "test:playback": "node --test --experimental-strip-types scripts/frame-cache.test.mjs scripts/playback-rendering.test.mjs",
    "test:issue-locate": "node --test --experimental-strip-types scripts/issue-locate.test.mjs",
    "check:wiki": "node scripts/check-wiki.mjs",
    "check:windows-cross": "node scripts/windows-cross-check.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "playwright-core": "^1.61.1",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  },
  "packageManager": "pnpm@10.12.1"
}
